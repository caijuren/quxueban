generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Family {
  id             Int             @id @default(autoincrement())
  name           String          @db.VarChar(100)
  familyCode     String          @unique @map("family_code") @db.VarChar(20)
  settings       Json            @default("{}")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  achievements   Achievement[]
  activeReadings ActiveReading[]
  bookAIInsights BookAIInsight[]
  bookReadStates BookReadState[]
  books          Book[]
  childTasks     ChildTask[]
  reports        Report[]
  taskTemplates  TaskTemplate[]
  tasks          Task[]
  userAIConfigs  UserAIConfig[]
  users          User[]
  weeklyPlans    WeeklyPlan[]

  @@map("families")
}

model User {
  id                 Int              @id @default(autoincrement())
  name               String           @db.VarChar(50)
  role               String           @db.VarChar(20)
  avatar             String           @default("🐛")
  passwordHash       String           @map("password_hash") @db.VarChar(255)
  familyId           Int              @map("family_id")
  status             String           @default("active") @db.VarChar(20)
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")
  dingtalkSecret     String?          @default("") @map("dingtalk_secret") @db.VarChar(100)
  dingtalkWebhook    String?          @default("") @map("dingtalk_webhook") @db.VarChar(500)
  dingtalkWebhookUrl String?          @default("") @map("dingtalk_webhook_url") @db.VarChar(500)
  achievementLogs    AchievementLog[]
  activeReadings     ActiveReading[]
  bookAIInsights     BookAIInsight[]
  bookReadStates     BookReadState[]
  books              Book[]           @relation("UserBooks")
  childTasks         ChildTask[]
  dailyCheckins      DailyCheckin[]
  readingLogs        ReadingLog[]
  reports            Report[]
  family             Family           @relation(fields: [familyId], references: [id])
  weeklyPlans        WeeklyPlan[]

  @@map("users")
}

model TaskTemplate {
  id                  Int         @id @default(autoincrement())
  name                String      @db.VarChar(100)
  type                String      @db.VarChar(30)
  subject             String?     @db.VarChar(30)
  singleDuration      Int         @default(30) @map("single_duration")
  difficulty          String?     @default("basic") @db.VarChar(20)
  description         String?
  coverUrl            String?     @map("cover_url") @db.VarChar(500)
  scheduleRule        String      @default("daily") @map("schedule_rule") @db.VarChar(20)
  defaultWeeklyTarget Int?        @map("default_weekly_target")
  familyId            Int         @map("family_id")
  isActive            Boolean     @default(true) @map("is_active")
  sortOrder           Int         @default(0) @map("sort_order")
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")
  childTasks          ChildTask[]
  family              Family      @relation(fields: [familyId], references: [id])

  @@map("task_templates")
}

model ChildTask {
  id                 Int          @id @default(autoincrement())
  childId            Int          @map("child_id")
  taskTemplateId     Int          @map("task_template_id")
  customName         String?      @map("custom_name") @db.VarChar(100)
  customDuration     Int?         @map("custom_duration")
  customScheduleRule String?      @map("custom_schedule_rule") @db.VarChar(20)
  weeklyTarget       Int?         @map("weekly_target")
  status             String       @default("active") @db.VarChar(20)
  startDate          DateTime?    @map("start_date")
  endDate            DateTime?    @map("end_date")
  skipHolidays       Boolean      @default(true) @map("skip_holidays")
  excludeDays        String?      @map("exclude_days") @db.VarChar(50)
  familyId           Int          @map("family_id")
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")
  child              User         @relation(fields: [childId], references: [id])
  family             Family       @relation(fields: [familyId], references: [id])
  taskTemplate       TaskTemplate @relation(fields: [taskTemplateId], references: [id])

  @@unique([childId, taskTemplateId])
  @@map("child_tasks")
}

model Task {
  id              Int          @id @default(autoincrement())
  familyId        Int          @map("family_id")
  name            String       @db.VarChar(100)
  category        String       @db.VarChar(30)
  type            String       @db.VarChar(20)
  timePerUnit     Int          @default(30) @map("time_per_unit")
  weeklyRule      Json?        @map("weekly_rule")
  sortOrder       Int          @default(0) @map("sort_order")
  isActive        Boolean      @default(true) @map("is_active")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  tags            Json?        @default("{}")
  appliesTo       Json?        @default("[]") @map("applies_to")
  scheduleRule    String       @default("daily") @map("schedule_rule") @db.VarChar(20)
  targetValue     Int?         @map("target_value")
  trackingType    String       @default("simple") @map("tracking_type") @db.VarChar(20)
  trackingUnit    String?      @map("tracking_unit") @db.VarChar(20)
  weeklyFrequency Int?         @map("weekly_frequency")
  family          Family       @relation(fields: [familyId], references: [id])
  weeklyPlans     WeeklyPlan[]

  @@map("tasks")
  @@index([familyId])
  @@index([isActive])
  @@index([familyId, isActive])
}

model WeeklyPlan {
  id           Int            @id @default(autoincrement())
  familyId     Int            @map("family_id")
  childId      Int            @map("child_id")
  taskId       Int            @map("task_id")
  target       Int            @default(1)
  progress     Int            @default(0)
  weekNo       String         @map("week_no") @db.VarChar(10)
  status       String         @default("active") @db.VarChar(20)
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  assignedDays Json?          @default("[]") @map("assigned_days")
  checkins     DailyCheckin[]
  child        User           @relation(fields: [childId], references: [id])
  family       Family         @relation(fields: [familyId], references: [id])
  task         Task           @relation(fields: [taskId], references: [id])

  @@map("weekly_plans")
  @@index([childId])
  @@index([weekNo])
  @@index([childId, weekNo])
}

model DailyCheckin {
  id             Int         @id @default(autoincrement())
  familyId       Int         @map("family_id")
  childId        Int         @map("child_id")
  taskId         Int         @map("task_id")
  planId         Int?        @map("plan_id")
  status         String      @db.VarChar(20)
  value          Int?
  checkDate      DateTime    @map("check_date")
  createdAt      DateTime    @default(now()) @map("created_at")
  completedValue Int?        @map("completed_value")
  notes          String?     @map("notes") @db.VarChar(500)
  child          User        @relation(fields: [childId], references: [id])
  plan           WeeklyPlan? @relation(fields: [planId], references: [id])

  @@map("daily_checkins")
  @@index([childId])
  @@index([checkDate])
  @@index([childId, checkDate])
  @@index([planId])
}

model Book {
  id             Int             @id @default(autoincrement())
  familyId       Int             @map("family_id")
  childId        Int?            @map("child_id")
  name           String          @db.VarChar(200)
  author         String          @default("") @db.VarChar(100)
  type           String          @default("fiction") @db.VarChar(30)
  coverUrl       String          @default("") @map("cover_url")
  status         String          @default("active") @db.VarChar(20)
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  characterTag   String          @default("") @map("character_tag") @db.VarChar(50)
  readCount      Int             @default(0) @map("read_count")
  totalPages     Int             @default(0) @map("total_pages")
  description    String          @default("")
  isbn           String          @default("") @db.VarChar(20)
  publisher      String          @default("") @db.VarChar(100)
  wordCount      Int?            @map("word_count")
  activeReadings ActiveReading[]
  bookAIInsights BookAIInsight[]
  bookReadStates BookReadState[]
  child          User?           @relation("UserBooks", fields: [childId], references: [id])
  family         Family          @relation(fields: [familyId], references: [id])
  readingLogs    ReadingLog[]

  @@map("books")
}

model ActiveReading {
  id           Int                  @id @default(autoincrement())
  familyId     Int                  @map("family_id")
  childId      Int                  @map("child_id")
  bookId       Int                  @map("book_id")
  readPages    Int                  @default(0) @map("read_pages")
  readCount    Int                  @default(0) @map("read_count")
  status       String               @default("reading") @db.VarChar(20)
  startedAt    DateTime             @default(now()) @map("started_at")
  completedAt  DateTime?            @map("completed_at")
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")
  book         Book                 @relation(fields: [bookId], references: [id])
  child        User                 @relation(fields: [childId], references: [id])
  family       Family               @relation(fields: [familyId], references: [id])
  progressLogs ReadingProgressLog[]

  @@unique([childId, bookId, status])
  @@map("active_readings")
}

model ReadingProgressLog {
  id              Int           @id @default(autoincrement())
  familyId        Int           @map("family_id")
  childId         Int           @map("child_id")
  bookId          Int           @map("book_id")
  activeReadingId Int           @map("active_reading_id")
  pagesRead       Int           @map("pages_read")
  totalReadPages  Int           @map("total_read_pages")
  readDate        DateTime      @map("read_date")
  createdAt       DateTime      @default(now()) @map("created_at")
  activeReading   ActiveReading @relation(fields: [activeReadingId], references: [id])

  @@map("reading_progress_logs")
}

model ReadingLog {
  id          Int      @id @default(autoincrement())
  familyId    Int      @map("family_id")
  childId     Int?     @map("child_id")
  bookId      Int      @map("book_id")
  pages       Int      @default(0)
  minutes     Int      @default(0)
  readDate    DateTime @map("read_date")
  createdAt   DateTime @default(now()) @map("created_at")
  effect      String   @default("") @db.VarChar(50)
  performance String   @default("") @db.VarChar(200)
  note        String   @default("") @db.VarChar(500)
  readStage   String   @default("") @map("read_stage") @db.VarChar(50)
  focusRating Int      @default(0) @map("focus_rating")
  tags        Json     @default("[]")
  endPage     Int      @default(0) @map("end_page")
  evidenceUrl String   @default("") @map("evidence_url") @db.VarChar(255)
  startPage   Int      @default(0) @map("start_page")
  book        Book     @relation(fields: [bookId], references: [id])
  child       User?    @relation(fields: [childId], references: [id])

  @@map("reading_logs")
}

model BookReadState {
  id         Int       @id @default(autoincrement())
  familyId   Int       @map("family_id")
  childId    Int       @map("child_id")
  bookId     Int       @map("book_id")
  status     String    @default("want_to_read") @db.VarChar(20)
  finishedAt DateTime? @map("finished_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  book       Book      @relation(fields: [bookId], references: [id])
  child      User      @relation(fields: [childId], references: [id])
  family     Family    @relation(fields: [familyId], references: [id])

  @@unique([childId, bookId])
  @@map("book_read_states")
}

model BookAIInsight {
  id        Int      @id @default(autoincrement())
  familyId  Int      @map("family_id")
  bookId    Int      @map("book_id")
  childId   Int?     @map("child_id")
  insights  Json     @default("{}")
  reportUrl String   @default("") @map("report_url")
  status    String   @default("pending") @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  book      Book     @relation(fields: [bookId], references: [id])
  child     User?    @relation(fields: [childId], references: [id])
  family    Family   @relation(fields: [familyId], references: [id])

  @@map("book_ai_insights")
}

model UserAIConfig {
  id        Int      @id @default(autoincrement())
  familyId  Int      @map("family_id")
  provider  String   @db.VarChar(50)
  config    Json     @default("{}")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  family    Family   @relation(fields: [familyId], references: [id])

  @@unique([familyId, provider])
  @@map("user_ai_configs")
}

model Achievement {
  id          Int              @id @default(autoincrement())
  familyId    Int              @map("family_id")
  icon        String           @default("🏆") @db.VarChar(10)
  name        String           @db.VarChar(50)
  description String           @default("") @db.VarChar(200)
  condition   Json             @default("{}")
  sortOrder   Int              @default(0) @map("sort_order")
  isActive    Boolean          @default(true) @map("is_active")
  createdAt   DateTime         @default(now()) @map("created_at")
  logs        AchievementLog[]
  family      Family           @relation(fields: [familyId], references: [id])

  @@map("achievements")
}

model AchievementLog {
  id            Int         @id @default(autoincrement())
  familyId      Int         @map("family_id")
  childId       Int         @map("child_id")
  achievementId Int         @map("achievement_id")
  unlockedAt    DateTime    @default(now()) @map("unlocked_at")
  achievement   Achievement @relation(fields: [achievementId], references: [id])
  child         User        @relation(fields: [childId], references: [id])

  @@map("achievement_logs")
}

model Report {
  id               Int      @id @default(autoincrement())
  familyId         Int      @map("family_id")
  childId          Int?     @map("child_id")
  type             String   @db.VarChar(20)
  title            String   @db.VarChar(200)
  content          Json
  startDate        DateTime @map("start_date")
  endDate          DateTime @map("end_date")
  isAutoGenerated  Boolean  @default(false) @map("is_auto_generated")
  isFavorite       Boolean  @default(false) @map("is_favorite")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  
  family           Family   @relation(fields: [familyId], references: [id])
  child            User?    @relation(fields: [childId], references: [id])
  
  @@index([familyId, type])
  @@index([familyId, createdAt])
  @@map("reports")
}
